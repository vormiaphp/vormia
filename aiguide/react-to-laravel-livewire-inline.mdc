## Full Example

### React Component

```jsx
function SearchableList({ category }) {
    const [items, setItems] = useState([]);
    const [search, setSearch] = useState('');

    useEffect(() => {
        fetch(`/api/items?category=${category}`)
            .then(r => r.json())
            .then(setItems);
    }, [category]);

    const filtered = useMemo(() =>
        items.filter(i => i.name.toLowerCase().includes(search.toLowerCase())),
        [items, search]
    );

    return (
        <div>
            <input value={search} onChange={e => setSearch(e.target.value)} placeholder="Search..." />
            <ul>
                {filtered.map(item => (
                    <li key={item.id}>{item.name}</li>
                ))}
            </ul>
        </div>
    );
}
```

### Livewire 4 Single-File Component

```php
<?php // resources/views/components/⚡searchable-list.blade.php
use Livewire\Attributes\Computed;
use Livewire\Component;
use Illuminate\Support\Facades\Log;

new class extends Component {
    public string $category = '';
    public array $items = [];
    public string $search = '';

    public function mount(string $category): void
    {
        $this->category = $category;

        try {
            $path = public_path('media/json/items.json');
            $all = json_decode(file_get_contents($path), true) ?? [];

            $this->items = collect($all)
                ->where('category', $category)
                ->values()
                ->toArray();
        } catch (\Throwable $e) {
            Log::error('Items load failed: ' . $e->getMessage());
            $this->items = [];
        }
    }

    #[Computed]
    public function filtered(): array
    {
        return collect($this->items)
            ->filter(fn($i) => str_contains(
                strtolower($i['name']),
                strtolower($this->search)
            ))
            ->values()
            ->toArray();
    }
};
?>

<div>
    <input
        wire:model.live.debounce.300ms="search"
        type="text"
        placeholder="Search..."
        class="border rounded px-3 py-2 w-full"
    />

    <ul class="mt-4 space-y-2">
        @foreach($this->filtered as $item)
            <li wire:key="item-{{ $item['id'] }}" class="p-2 border rounded">
                {{ $item['name'] }}
            </li>
        @endforeach
    </ul>
</div>

<style>
input:focus {
    outline: 2px solid #3b82f6;
