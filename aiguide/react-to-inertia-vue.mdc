## Full Example

### React Component (Before)

```jsx
function ProductShow({ productId }) {
    const [product, setProduct] = useState(null);

    useEffect(() => {
        fetch(`/api/products/${productId}`).then(r => r.json()).then(setProduct);
    }, [productId]);

    const [comment, setComment] = useState('');

    const submitComment = async () => {
        await fetch(`/api/products/${productId}/comments`, {
            method: 'POST',
            body: JSON.stringify({ body: comment }),
        });
    };

    if (!product) return null;

    return (
        <div>
            <h1>{product.name}</h1>
            <textarea value={comment} onChange={e => setComment(e.target.value)} />
            <button onClick={submitComment}>Comment</button>
        </div>
    );
}
```

### Vue + Inertia (After)

```php
// app/Http/Controllers/ProductController.php
public function show(Product $product): \Inertia\Response
{
    return Inertia::render('Products/Show', ['product' => $product]);
}

public function storeComment(Request $request, Product $product): \Illuminate\Http\RedirectResponse
{
    $product->comments()->create($request->validate(['body' => 'required|string']));
    return back()->with('success', 'Comment added.');
}
```

```vue
<!-- resources/js/Pages/Products/Show.vue -->
<script setup>
import { useForm } from '@inertiajs/vue3';
import AppLayout from '@/Layouts/AppLayout.vue';

defineOptions({ layout: AppLayout });

defineProps({ product: Object });

const form = useForm({ body: '' });

const submit = () => {
    form.post(route('products.comments.store', product.id), {
        onSuccess: () => form.reset(),
    });
};
</script>

<template>
    <div>
        <h1 class="text-2xl font-bold">{{ product.name }}</h1>

        <form @submit.prevent="submit" class="mt-4">
            <textarea
                v-model="form.body"
                class="border rounded p-2 w-full"
                rows="3"
            />
            <p v-if="form.errors.body" class="text-red-500 text-sm">{{ form.errors.body }}</p>
            <button
                type="submit"
                :disabled="form.processing"
                class="bg-blue-600 text-white px-4 py-2 rounded mt-2"
            >
                Comment
            </button>
        </form>
    </div>
</template>
```

