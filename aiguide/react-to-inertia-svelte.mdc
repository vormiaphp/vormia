## Full Example

### React Component (Before)

```jsx
function ProductShow({ productId }) {
    const [product, setProduct] = useState(null);

    useEffect(() => {
        fetch(`/api/products/${productId}`).then(r => r.json()).then(setProduct);
    }, [productId]);

    if (!product) return null;

    const [qty, setQty] = useState(1);
    const total = useMemo(() => product.price * qty, [product.price, qty]);

    return (
        <div>
            <h1>{product.name}</h1>
            <input type="number" value={qty} onChange={e => setQty(+e.target.value)} min="1" />
            <p>Total: ${total}</p>
        </div>
    );
}
```

### Svelte + Inertia (After)

```php
// app/Http/Controllers/ProductController.php
public function show(Product $product): \Inertia\Response
{
    return Inertia::render('Products/Show', ['product' => $product]);
}
```

```svelte
<!-- resources/js/Pages/Products/Show.svelte -->
<script>
    import AppLayout from '@/Layouts/AppLayout.svelte';
    import { defineOptions } from '@inertiajs/svelte';

    defineOptions({ layout: AppLayout });

    // Product arrives from Laravel — no fetch needed
    let { product } = $props();

    // Local state
    let qty = $state(1);

    // Derived value — auto-updates when product.price or qty change
    let total = $derived(product.price * qty);
</script>

<div>
    <h1 class="text-2xl font-bold">{product.name}</h1>

    <input
        type="number"
        bind:value={qty}
        min="1"
        class="border rounded px-3 py-2 w-24 mt-2"
    />

    <p class="mt-2 text-lg">Total: ${total.toFixed(2)}</p>
</div>
```

