## Full Example

### React Web (Before)

```tsx
export default function CreateProductForm() {
    const [name, setName] = useState('');
    const [errors, setErrors] = useState({});
    const [loading, setLoading] = useState(false);

    const handleSubmit = async (e) => {
        e.preventDefault();
        // ... submit
    };

    return (
        <form onSubmit={handleSubmit} className="p-4 space-y-4">
            <h1 className="text-2xl font-bold">New Product</h1>
            <div>
                <label className="text-sm font-medium">Name</label>
                <input
                    value={name}
                    onChange={e => setName(e.target.value)}
                    className="border rounded px-3 py-2 w-full"
                />
                {errors.name && <p className="text-red-500 text-sm">{errors.name[0]}</p>}
            </div>
            <button
                type="submit"
                disabled={loading}
                className="bg-blue-600 text-white px-4 py-2 rounded w-full"
            >
                {loading ? 'Saving...' : 'Create Product'}
            </button>
        </form>
    );
}
```

### Expo + GlueStack UI (After)

```tsx
// app/products/create.tsx
import { useState } from 'react';
import { router } from 'expo-router';
import {
    VStack, Heading, FormControl, FormControlLabel, FormControlLabelText,
    FormControlError, FormControlErrorText, Input, InputField,
    Button, ButtonText, ButtonSpinner, useToast, Toast, ToastTitle,
} from '@gluestack-ui/themed';
import { SafeAreaView } from 'react-native-safe-area-context';
import client from '@/api/client';

export default function CreateProductScreen() {
    const [name, setName] = useState('');
    const [errors, setErrors] = useState<Record<string, string[]>>({});
    const [loading, setLoading] = useState(false);
    const toast = useToast();

    const handleSubmit = async () => {
        setLoading(true);
        setErrors({});
        try {
            await client.post('/products', { name });
            toast.show({
                render: ({ id }) => (
                    <Toast action="success" id={id}>
                        <ToastTitle>Product created!</ToastTitle>
                    </Toast>
                ),
            });
            router.back();
        } catch (err: any) {
            if (err.response?.status === 422) {
                setErrors(err.response.data.errors ?? {});
            }
        } finally {
            setLoading(false);
        }
    };

    return (
        <SafeAreaView style={{ flex: 1, backgroundColor: '#fff' }}>
            <VStack space="lg" p="$4">
                <Heading size="2xl">New Product</Heading>

                <FormControl isInvalid={!!errors.name} isRequired>
                    <FormControlLabel>
                        <FormControlLabelText>Name</FormControlLabelText>
                    </FormControlLabel>
                    <Input>
                        <InputField
                            value={name}
                            onChangeText={setName}
                            placeholder="Product name"
                            autoCapitalize="none"
                        />
                    </Input>
                    {errors.name && (
                        <FormControlError>
                            <FormControlErrorText>{errors.name[0]}</FormControlErrorText>
                        </FormControlError>
                    )}
                </FormControl>

                <Button onPress={handleSubmit} isDisabled={loading}>
                    {loading ? <ButtonSpinner mr="$2" /> : null}
                    <ButtonText>{loading ? 'Saving...' : 'Create Product'}</ButtonText>
                </Button>
            </VStack>
        </SafeAreaView>
    );
}
```

