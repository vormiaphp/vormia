{
    "name": "vormiaphp/vormia",
    "description": "A comprehensive Laravel package for user management, roles, permissions, and utilities",
    "keywords": [
        "laravel",
        "php",
        "roles",
        "permissions",
        "user-management",
        "vormia"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Josh Minga",
            "email": "packages@vormia.com",
            "homepage": "https://packages.vormia.com/vormiaphp",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "VormiaPHP\\Vormia\\": "src/",
            "Vormia\\": "src/"
        },
        "exclude-from-classmap": [
            "src/stubs/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "workbench/app/",
            "VormiaPHP\\Vormia\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "VormiaPHP\\Vormia\\VormiaServiceProvider"
            ],
            "aliases": {
                "Vormia": "VormiaPHP\\Vormia\\Facades\\Vormia"
            }
        }
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0|^13.0",
        "intervention/image": "^3.11"
    },
    "suggest": {
        "livewire/livewire": "For Livewire traits (WithNotifications)"
    },
    "require-dev": {
        "laravel/sanctum": "^4.3",
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5|^12.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage",
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ]
    }
}
